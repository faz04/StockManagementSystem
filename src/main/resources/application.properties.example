# =============================================
# EXAMPLE CONFIGURATION - DO NOT USE AS-IS
# Copy this file to application.properties and
# fill in your actual database credentials
# =============================================

# SQL Server Database Configuration
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=stock_management_DB;encrypt=true;trustServerCertificate=true
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.datasource.driver-class-name=com.microsoft.sqlserver.jdbc.SQLServerDriver

# JPA/Hibernate Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.SQLServerDialect
spring.jpa.show-sql=true

# Server Configuration
server.port=8080

# Application Configuration
app.name=Stock Management System
app.version=1.0.0
